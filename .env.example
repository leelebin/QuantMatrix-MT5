NODE_ENV=development
PORT=5000

# JWT (auto-generated if not set)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_REFRESH_EXPIRE=7d

# Email (optional, for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@quantmatrix.com
FROM_NAME=QuantMatrix

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5000
PUBLIC_BASE_URL=

# Remote browser access
ALLOW_SELF_REGISTRATION=false
REMOTE_URL_NOTIFY=true
NGROK_AUTHTOKEN=
# Optional fixed outer access credentials for ngrok
# NGROK_BASIC_AUTH_USER=qmremote
# NGROK_BASIC_AUTH_PASSWORD=change-this-password
# Optional override for the local ngrok inspector API
# NGROK_API_URL=http://127.0.0.1:4040/api/tunnels

# Reverse proxy handling (use 1 for ngrok / Cloudflare / other single-hop proxies)
TRUST_PROXY=1

# Data snapshot cloud upload via rclone.
# DATA_SYNC_REMOTE must match the remote name from `rclone config`.
DATA_SYNC_ENABLED=false
DATA_SYNC_SCHEDULE_ENABLED=false
DATA_SYNC_PROVIDER=rclone
DATA_SYNC_REMOTE=quantmatrix-drive
DATA_SYNC_REMOTE_PATH=QuantMatrix/backups
DATA_SYNC_DAILY_TIME=23:59
DATA_SYNC_TIMEZONE=Asia/Kuala_Lumpur
DATA_SYNC_KEEP_LOCAL_DAYS=14
DATA_SYNC_NOTIFY_TELEGRAM=true

# MT5 Broker Connection (legacy fallback used when scoped values below are empty)
MT5_LOGIN=your-mt5-login
MT5_PASSWORD=your-mt5-password
MT5_SERVER=your-broker-server

# Live MT5 connection (REAL account recommended)
MT5_LIVE_LOGIN=
MT5_LIVE_PASSWORD=
MT5_LIVE_SERVER=
MT5_LIVE_PATH=C:\MT5-Live\terminal64.exe

# Paper MT5 connection (DEMO/CONTEST account required)
MT5_PAPER_LOGIN=
MT5_PAPER_PASSWORD=
MT5_PAPER_SERVER=
MT5_PAPER_PATH=C:\MT5-Paper\terminal64.exe

# Runtime isolation guard.
# Keep this true for normal use: live and paper must point to two different
# MT5 terminal64.exe files from two separate MT5 installations. Never point
# MT5_LIVE_PATH and MT5_PAPER_PATH at the same terminal. When live and paper
# run together, missing or shared paths hard-fail to prevent paper attaching
# to the live real-account terminal.
MT5_STRICT_RUNTIME_ISOLATION=true

# Optional: Path to MT5 terminal executable for legacy fallback
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Optional: Python executable path (defaults to 'python')
# PYTHON_PATH=python

# Telegram Bot Notifications
# 1. Create a bot via @BotFather on Telegram, get the token
# 2. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_TRADE_OPEN_MERGE_WINDOW_MS=10000

# Trading Configuration
MAX_RISK_PER_TRADE=0.05
MAX_DAILY_LOSS=0.25
MAX_DRAWDOWN=0.5
MAX_CONCURRENT_POSITIONS=5
MAX_POSITIONS_PER_SYMBOL=2
TRADING_ENABLED=false
ALLOW_LIVE_TRADING=false

# Paper Trading Mode
PAPER_TRADING_ENABLED=false
# Daily report will be sent to Telegram at this time (24h format, server timezone)
DAILY_REPORT_HOUR=23
DAILY_REPORT_MINUTE=55
